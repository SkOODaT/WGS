<Window x:Class="WGS.Views.SteamGuardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Guard" Width="420" Height="220"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"
            Background="{StaticResource BgDeepBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0">
                <TextBlock Text="🔒  Steam Guard" VerticalAlignment="Center" Margin="16,0"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24" VerticalAlignment="Center">
                <TextBlock TextWrapping="Wrap" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,16">
                    If Steam Guard is enabled, enter the code from your email or authenticator app. Leave empty if not needed (session already cached).
                </TextBlock>

                <TextBox x:Name="CodeBox"
                         Style="{StaticResource DarkTextBox}"
                         FontSize="18" FontFamily="Consolas"
                         MaxLength="10"
                         HorizontalContentAlignment="Center"
                         Margin="0,0,0,16"
                         KeyDown="CodeBox_KeyDown"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="Confirm" Style="{StaticResource PrimaryButton}"
                            Click="Confirm_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
