<UserControl x:Class="WGS.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WGS.Views"
             Background="{StaticResource BgDeepBrush}">

    <UserControl.Resources>
        <!-- Metric card progress bar color selector -->
        <local:PercentToColorConverter x:Key="PctColor"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>

            <!-- Debug header - poistetaan kun toimii -->
            <Border Background="#1A3A2A" CornerRadius="6" Padding="16,10" Margin="0,0,0,16">
                <TextBlock Text="📊 DASHBOARD — näkymä toimii!" FontSize="14" FontWeight="Bold"
                           Foreground="#3FB950"/>
            </Border>

            <!-- ── Section: System ── -->
            <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"
                       Foreground="{StaticResource TextMutedBrush}"/>

            <WrapPanel Margin="0,0,0,24">

                <!-- CPU Card -->
                <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="CPU" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                            <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:F1}}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="%" FontSize="18" VerticalAlignment="Bottom" Margin="2,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding CpuPercent, Mode=OneWay}" Maximum="100" Height="6"
                                     Foreground="{Binding CpuPercent, Mode=OneWay, Converter={StaticResource PctColor}}"
                                     Background="{StaticResource BgSurface2Brush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- Memory Card -->
                <Border Style="{StaticResource Card}" Width="260" Margin="0,0,16,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="MEMORY (RAM)" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                            <TextBlock Text="{Binding RamUsedGb, StringFormat={}{0:F1}}"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="GB" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,6"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text=" / " FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding RamTotalGb, StringFormat={}{0:F1}}"
                                       FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="GB" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,6"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding RamPercent, Mode=OneWay}" Maximum="100" Height="6"
                                     Foreground="{Binding RamPercent, Mode=OneWay, Converter={StaticResource PctColor}}"
                                     Background="{StaticResource BgSurface2Brush}"
                                     BorderThickness="0"/>
                        <TextBlock Text="{Binding RamPercent, StringFormat={}({0:F0}% used)}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Disk Cards — one per drive -->
                <ItemsControl ItemsSource="{Binding Drives}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Width="220" Margin="0,0,16,16" Padding="20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="DISK " FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBlueBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding UsedGb, StringFormat={}{0:F1}}"
                                                   FontSize="36" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="GB" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,6"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text=" / " FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding TotalGb, StringFormat={}{0:F1}}"
                                                   FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="GB" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,6"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="6"
                                                 Foreground="{Binding UsedPercent, Mode=OneWay, Converter={StaticResource PctColor}}"
                                                 Background="{StaticResource BgSurface2Brush}"
                                                 BorderThickness="0"/>
                                    <TextBlock Text="{Binding UsedPercent, StringFormat={}({0:F0}% used)}"
                                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </WrapPanel>

            <!-- ── Section: Servers ── -->
            <TextBlock Text="SERVERS" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"
                       Foreground="{StaticResource TextMutedBrush}"/>

            <WrapPanel Margin="0,0,0,24">

                <!-- Total Servers -->
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,16,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="TOTAL" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ServerCount}" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="servers" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Online -->
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,16,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="RUNNING" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding OnlineCount}" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="active" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stopped -->
                <Border Style="{StaticResource Card}" Width="160" Margin="0,0,16,16" Padding="20">
                    <StackPanel>
                        <TextBlock Text="STOPPED" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StoppedCount}" FontSize="48" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="stopped" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
