<UserControl x:Class="WGS.Views.MachinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeepBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16">
            <StackPanel>
                <TextBlock Text="🖥 Remote Machines" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"
                           Text="Master control panel — add slave machines and manage their servers remotely."/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <!-- Add machine form -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Add Slave Machine" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding NewMachineName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="URL  (http://ip:port)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource DarkTextBox}" FontFamily="Consolas"
                                         Text="{Binding NewMachineUrl, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Token (from slave settings)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource DarkTextBox}" FontFamily="Consolas"
                                         Text="{Binding NewMachineToken, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <Button Grid.Column="6" Content="＋ Add" Style="{StaticResource PrimaryButton}"
                                    VerticalAlignment="Bottom" Command="{Binding AddMachineCommand}"/>
                        </Grid>
                        <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                            On the slave: Settings → Remote Control — Slave Setup → enable Slave, set port &amp; token, Save &amp; Apply.
                            Copy the URL and Token from the blue info box.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- No machines placeholder -->
                <TextBlock Text="No machines added yet." FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"
                           Visibility="{Binding RemoteMachines.Count, Converter={StaticResource ZeroToVis}, Mode=OneWay}"/>

                <!-- Machine cards -->
                <ItemsControl ItemsSource="{Binding RemoteMachines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- x:Name trick: give the outer card a name so inner bindings can reach MachineViewModel -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12" x:Name="MachineCard">
                                <StackPanel>
                                    <!-- Machine header row -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#8B949E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                            <Setter Property="Fill" Value="#3FB950"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding MachineName}" FontSize="15" FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding MachineUrl}" FontSize="11"
                                                       FontFamily="Consolas" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="🗑 Remove" Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.RemoveMachineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>

                                    <!-- Server list -->
                                    <TextBlock Text="No servers visible — slave offline or no servers installed."
                                               FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="20,0,0,0"
                                               Visibility="{Binding Servers.Count, Converter={StaticResource ZeroToVis}, Mode=OneWay}"/>

                                    <ItemsControl ItemsSource="{Binding Servers}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="6"
                                                        Padding="12,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Fill" Value="#8B949E"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                                    <Setter Property="Fill" Value="#3FB950"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                                    <Setter Property="Fill" Value="#D29922"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                                                                    <Setter Property="Fill" Value="#D29922"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Installing">
                                                                                    <Setter Property="Fill" Value="#58A6FF"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                                    <Setter Property="Fill" Value="#58A6FF"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                                    <Setter Property="Fill" Value="#F85149"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <TextBlock FontWeight="SemiBold" FontSize="13"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           Text="{Binding DisplayName}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="15,2,0,0">
                                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding GameId}"/>
                                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Text="  ·  "/>
                                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                                                           Text="{Binding Status}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="▶ Start" Margin="0,0,4,0"
                                                                    Command="{Binding DataContext.StartServerCommand, RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=2}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                                                        <Setter Property="IsEnabled" Value="True"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Stopping">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Installing">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Updating">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Content="■ Stop"
                                                                    Command="{Binding DataContext.StopServerCommand, RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=2}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Starting">
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Content="↺" Margin="4,0,0,0"
                                                                    Width="32" Padding="0" ToolTip="Restart"
                                                                    Command="{Binding DataContext.RestartServerCommand, RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=2}}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
