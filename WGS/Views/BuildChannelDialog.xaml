<Window x:Class="WGS.Views.BuildChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#1c2128" CornerRadius="10" BorderBrush="#30363d" BorderThickness="1">
        <StackPanel Margin="24,20">
            <Grid Margin="0,0,0,6">
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                <Button x:Name="RefreshButton" Content="🔄 Check updates" HorizontalAlignment="Right"
                        Padding="8,3" FontSize="11" Background="#21262d" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="RefreshClick"
                        ToolTip="Re-check the latest Recommended/Latest build numbers from Cfx.re"/>
            </Grid>
            <TextBlock Text="Which build should WGS install?" FontSize="12"
                       Foreground="#8b949e" Margin="0,0,0,18"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="32" Margin="0,0,8,0"
                        Background="#21262d" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="CancelClick"/>
                <Button x:Name="RecommendedButton" Width="150" Height="32" Margin="0,0,8,0"
                        Background="#238636" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RecommendedClick"
                        ToolTip="Stable build Cfx.re currently recommends for production"/>
                <Button x:Name="LatestButton" Width="150" Height="32"
                        Background="#9e6a03" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="LatestClick"
                        ToolTip="Newest build — has the latest features, but can be buggy"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
