<Window x:Class="WGS.Views.AddScheduleTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add scheduled task" Height="340" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117"
        Foreground="#e6edf3"
        BorderBrush="#30363d" BorderThickness="1"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <StackPanel Margin="24">
        <TextBlock Text="Scheduled Task" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"
                   Foreground="#e6edf3"/>

        <TextBlock Text="Action" Foreground="#8b949e" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox x:Name="CbAction" Margin="0,0,0,14" Style="{StaticResource DarkComboBox}">
            <ComboBoxItem Content="Restart" IsSelected="True"/>
            <ComboBoxItem Content="Stop"/>
            <ComboBoxItem Content="Start"/>
            <ComboBoxItem Content="Backup"/>
            <ComboBoxItem Content="Update"/>
        </ComboBox>

        <TextBlock Text="Frequency" Foreground="#8b949e" FontSize="12" Margin="0,0,0,4"/>
        <ComboBox x:Name="CbFreq" Margin="0,0,0,14" Style="{StaticResource DarkComboBox}"
                  SelectionChanged="CbFreq_SelectionChanged">
            <ComboBoxItem Content="Daily" IsSelected="True"/>
            <ComboBoxItem Content="Weekly"/>
        </ComboBox>

        <StackPanel x:Name="DayPanel" Visibility="Collapsed" Margin="0,0,0,14">
            <TextBlock Text="Day of week" Foreground="#8b949e" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="CbDay" Style="{StaticResource DarkComboBox}">
                <ComboBoxItem Content="Monday" IsSelected="True"/>
                <ComboBoxItem Content="Tuesday"/>
                <ComboBoxItem Content="Wednesday"/>
                <ComboBoxItem Content="Thursday"/>
                <ComboBoxItem Content="Friday"/>
                <ComboBoxItem Content="Saturday"/>
                <ComboBoxItem Content="Sunday"/>
            </ComboBox>
        </StackPanel>

        <TextBlock Text="Time (HH:mm)" Foreground="#8b949e" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="TbTime" Text="04:00" Margin="0,0,0,20" Padding="10,6"
                 Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                 FontFamily="Consolas"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,8" Margin="0,0,8,0"
                    Background="#21262d" Foreground="#e6edf3" BorderThickness="1" BorderBrush="#30363d"
                    Cursor="Hand"/>
            <Button Content="Add task" Click="Add_Click" Padding="16,8"
                    Background="#1f6feb" Foreground="#fff" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
