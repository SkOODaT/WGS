<Window x:Class="WGS.Views.CloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="320" Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#1E1E2E" CornerRadius="10" BorderBrush="#3A3A5C" BorderThickness="1">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="What do you want to do?" Foreground="White" FontSize="14"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="✕" Width="22" Height="22" Padding="0" HorizontalAlignment="Right"
                        Background="Transparent" Foreground="#9A9AB0" BorderThickness="0"
                        Cursor="Hand" Click="CancelClick" ToolTip="Dismiss (do nothing)"/>
            </Grid>
            <Grid Grid.Row="1">
                <Button Content="Minimize to Tray" Width="120" Height="32" HorizontalAlignment="Left"
                        Background="#2D2D44" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="MinimizeClick"/>
                <Button Content="Close WGS" Width="100" Height="32" HorizontalAlignment="Right"
                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="CloseAppClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
