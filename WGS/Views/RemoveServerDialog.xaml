<Window x:Class="WGS.Views.RemoveServerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="400" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#1c2128" CornerRadius="10" BorderBrush="#30363d" BorderThickness="1">
        <StackPanel Margin="24,20">
            <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                       Foreground="White" Margin="0,0,0,6"/>
            <TextBlock Text="Valitse miten palvelin poistetaan:" FontSize="12"
                       Foreground="#8b949e" Margin="0,0,0,18"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Peruuta" Width="80" Height="32" Margin="0,0,8,0"
                        Background="#21262d" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="CancelClick"/>
                <Button Content="Poista listalta" Width="110" Height="32" Margin="0,0,8,0"
                        Background="#238636" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RemoveOnlyClick"
                        ToolTip="Poistaa palvelimen listalta, tiedostot jäävät levylle"/>
                <Button Content="🗑 Poista + tiedostot" Width="140" Height="32"
                        Background="#da3633" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="RemoveWithFilesClick"
                        ToolTip="Poistaa palvelimen listalta JA poistaa kaikki asennustiedostot levyltä"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
