<UserControl x:Class="WGS.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeepBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Settings" Style="{StaticResource SectionHeader}" FontSize="22"/>

            <!-- Discord -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Discord Notifications" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <CheckBox IsChecked="{Binding DiscordEnabled}" Style="{StaticResource DarkCheckBox}"
                              Content="Enable Discord notifications" Margin="0,0,0,12"/>
                    <TextBlock Text="Webhook URL" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding DiscordWebhookUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Test" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Command="{Binding TestDiscordCommand}"/>
                    </Grid>
                    <WrapPanel>
                        <CheckBox IsChecked="{Binding NotifyOnStart}"  Style="{StaticResource DarkCheckBox}" Content="Start"  Margin="0,0,16,8"/>
                        <CheckBox IsChecked="{Binding NotifyOnStop}"   Style="{StaticResource DarkCheckBox}" Content="Stop"    Margin="0,0,16,8"/>
                        <CheckBox IsChecked="{Binding NotifyOnCrash}"  Style="{StaticResource DarkCheckBox}" Content="Crash"  Margin="0,0,16,8"/>
                        <CheckBox IsChecked="{Binding NotifyOnUpdate}" Style="{StaticResource DarkCheckBox}" Content="Update"    Margin="0,0,16,8"/>
                    </WrapPanel>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Margin="0,12,0,0" Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- Discord Remote Control Bot -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Discord Remote Control Bot" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                        Control your servers from Discord. Create a bot at discord.com/developers, give it Read/Send Messages permission in your control channel, paste the token and channel ID below.
                    </TextBlock>

                    <CheckBox IsChecked="{Binding BotEnabled}" Style="{StaticResource DarkCheckBox}"
                              Content="Enable Discord bot" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bot Token" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Control Channel ID" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BotChannelId, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Command prefix" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BotPrefix, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Allowed User IDs (comma-separated, empty = everyone)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding BotAllowedUsers, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Status: " FontSize="12" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding BotStatus}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,16,0"/>
                        <Button Content="🧪 Test connection" Style="{StaticResource GhostButton}"
                                Margin="0,0,8,0" Command="{Binding TestBotCommand}"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Web API -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Web Remote Control (HTTP API)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                        Enables a built-in web server for remote management from a browser or phone.
                        Open http://your-ip:port in any browser. REST API available at /api/servers.
                    </TextBlock>
                    <CheckBox IsChecked="{Binding WebApiEnabled}" Style="{StaticResource DarkCheckBox}"
                              Content="Enable Web API" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding WebApiPort, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Access token (leave empty to auto-generate)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource DarkTextBox}" FontFamily="Consolas"
                                     Text="{Binding WebApiToken, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Status: " FontSize="12" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding WebApiStatus}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,16,0"/>
                        <Button Content="Save" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveSettingsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- General -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General Settings" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="Default install directory" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"
                             Text="{Binding DefaultInstallRoot, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Backup folder" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Command="{Binding BrowseBackupPathCommand}"/>
                    </Grid>
                    <TextBlock Text="SteamCMD directory" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SteamCmdPath}" IsReadOnly="True"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Margin="0,12,0,0" Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- Steam login -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Steam Login" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"
                               Text="Required for games that don't support anonymous download (e.g. Wreckfest 2, Conan Exiles)"/>
                    <TextBlock Text="Steam username" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"
                             Text="{Binding SteamLogin, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Steam password" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="SteamPassBox" Margin="0,0,0,12"
                                 Background="#161B22" Foreground="#E6EDF3"
                                 BorderBrush="#30363D" BorderThickness="1" Padding="10,8"
                                 PasswordChanged="SteamPassBox_PasswordChanged"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               Text="⚠ Password is stored in plain text. Use a dedicated Steam account for servers."/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Margin="0,12,0,0" Command="{Binding SaveSettingsCommand}"/>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="About" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22">
                        <Run Text="Windows Game Server (WGS) v1.0.1" FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}"/>
                        <LineBreak/>
                        <Run Text="Supports 12 games: Valheim, Minecraft, Conan Exiles, Rust, 7 Days to Die,"/>
                        <LineBreak/>
                        <Run Text="Euro Truck Simulator 2, Survive the Nights, Wreckfest, Wreckfest 2,"/>
                        <LineBreak/>
                        <Run Text="The Forest, Sons of the Forest, Arma Reforger"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
