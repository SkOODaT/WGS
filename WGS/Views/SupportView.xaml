<UserControl x:Class="WGS.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wgs="clr-namespace:WGS"
             Background="{StaticResource BgDeepBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="680" HorizontalAlignment="Left">

            <!-- ── Logo + Title ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Image Source="pack://application:,,,/WindowsGameServer;component/wgs.png"
                       Width="52" Height="52" RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"/>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Windows Game Server"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{x:Static wgs:AppInfo.VersionTag}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Free, open-source Windows game server management panel."
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>

            <!-- ── About section ── -->
            <TextBlock Text="ABOUT" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Static wgs:AppInfo.Version}"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Author"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="MadBee71"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="License"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="MIT — Free to use and modify"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Platform"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text=".NET 8  ·  WPF  ·  Windows 10+"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Supported Games"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="63+ built-in plugins + Custom Plugin Creator"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Features ── -->
            <TextBlock Text="FEATURES" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                <WrapPanel>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🎮 90+ Games" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="⬇ SteamCMD" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🔄 Auto Restart" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="💾 Backups" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🛡 Firewall" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="📟 RCON" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="📊 Dashboard" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="⚙ CPU Affinity" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🔔 System Tray" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🔒 DPAPI Encryption" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BgSurface2Brush}" CornerRadius="4"
                            Padding="10,5" Margin="0,0,8,8">
                        <TextBlock Text="🔧 Plugin Creator" FontSize="12"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </Border>
                </WrapPanel>
            </Border>

            <!-- ── Support section ── -->
            <TextBlock Text="SUPPORT THE PROJECT" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⭐  Star on GitHub"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16">
                        The biggest help is completely free: if WGS is useful to you, starring the
                        repo is the main way other people find the project.
                    </TextBlock>

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Padding="20,10"
                            FontSize="13"
                            Tag="https://github.com/MadBee71/WGS"
                            Click="GitHubButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⭐  Star on GitHub" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="https://github.com/MadBee71/WGS"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,10,0,0"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               MouseLeftButtonUp="GitHubLink_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="☕  Buy Me a Coffee"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,16">
                        If you'd also like to chip in financially, that's entirely optional and never
                        expected — it goes toward keeping the project's development going, not "buying"
                        features or support.
                    </TextBlock>

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Padding="20,10"
                            FontSize="13"
                            Tag="https://ko-fi.com/madbee71"
                            Click="KoFiButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❤  Support on Ko-fi" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="https://ko-fi.com/madbee71"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,10,0,0"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               MouseLeftButtonUp="KoFiLink_Click"/>
                </StackPanel>
            </Border>

            <!-- ── Footer ── -->
            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,24"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                WGS  ·  2026 © MadBee71  ·  MIT License
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
