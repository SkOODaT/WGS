<Window x:Class="WGS.Views.ExportPluginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export plugin as .cs"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">

    <Border Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="8" Padding="24">
        <StackPanel>
            <TextBlock Text="Export plugin as .cs"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Valitse plugin jota haluat exportata. Tulos on muokattava .cs-tiedosto."
                       FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <TextBlock Text="PLUGIN" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
            <ComboBox x:Name="PluginCombo"
                      Style="{StaticResource DarkComboBox}"
                      Margin="0,0,0,20">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding GameName}" FontWeight="SemiBold"
                                       Foreground="#E6EDF3" MinWidth="160"/>
                            <Border Background="#21262D" CornerRadius="3" Padding="6,2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Category}" Foreground="#58A6FF" FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Peruuta" Style="{StaticResource GhostButton}"
                        Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="⬇ Export" Style="{StaticResource PrimaryButton}"
                        Click="Export_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
