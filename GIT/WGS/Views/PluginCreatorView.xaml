<Window x:Class="WGS.Views.PluginCreatorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add game module"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDeepBrush}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
        <StackPanel Margin="28">

            <!-- Title bar -->
            <Grid Margin="0,0,0,20" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="+ Add game module" Style="{StaticResource SectionHeader}" FontSize="16"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="28" Padding="0"
                        Style="{StaticResource DangerButton}" Click="CloseBtn_Click"/>
            </Grid>

            <!-- Game Name -->
            <TextBlock Text="Game name *" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

            <!-- Game ID (auto) -->
            <TextBlock Text="Game ID (automatic)" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding GameId, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

            <!-- Description -->
            <TextBlock Text="Description" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

            <!-- Category -->
            <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding Category}"
                      Style="{StaticResource DarkComboBox}" Margin="0,0,0,12"/>

            <!-- Executable -->
            <TextBlock Text="Executable *" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Executable, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

            <!-- Steam App ID -->
            <TextBlock Text="Steam App ID (0 = no Steam)" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding SteamAppId, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

            <!-- Ports & Players row -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Default port" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DefaultPort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Query port" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DefaultQueryPort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Max players" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DefaultMaxPlayers, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"/>
                </StackPanel>
            </Grid>

            <!-- Checkboxes -->
            <CheckBox Content="Requires Steam login" IsChecked="{Binding RequiresSteamLogin}"
                      Style="{StaticResource DarkCheckBox}" Margin="0,0,0,8"/>
            <CheckBox Content="Supports RCON commands" IsChecked="{Binding HasRcon}"
                      Style="{StaticResource DarkCheckBox}" Margin="0,0,0,16"/>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F85149" FontSize="12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Create module" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateCommand}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
